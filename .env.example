# ──────────────────────────────────────────────────────────────
# Archivo de configuración de entorno  (.env)
# Copiar este archivo como  .env  y ajustar los valores
# ──────────────────────────────────────────────────────────────

# Clave secreta de Flask (cambiar por una cadena aleatoria larga)
SECRET_KEY=cambia-esta-clave-secreta-por-una-muy-segura

# Cadena de conexión a PostgreSQL
DATABASE_URL=postgresql://uaded:uaded123@localhost:5432/uaded_db

# Entorno de ejecución: development | production
FLASK_ENV=development
FLASK_APP=run.py
